{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "orders-route": {
        "ClusterId": "shop-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "wms-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "shop-cluster": {
        "Destinations": {
          "shop-api": {
            "Address": "http://shop-api:8080"
          }
        }
      },
      "wms-cluster": {
        "Destinations": {
          "wms-api": {
            "Address": "http://wms-api:8080"
          }
        }
      }
    }
  }
}