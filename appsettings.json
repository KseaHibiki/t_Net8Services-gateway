{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "redis": "localhost:6379"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 10
  },
  "Jwt": {
    "Key": "YourSuperSecretKeyAtLeast32CharactersLong!!",
    "Issuer": "Identity.API",
    "Audience": "Microservices"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "shop-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "wms-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-api": {
            "Address": "http://identity-api:8080"
          }
        }
      },
      "shop-cluster": {
        "Destinations": {
          "shop-api": {
            "Address": "http://shop-api:8080"
          }
        }
      },
      "wms-cluster": {
        "Destinations": {
          "wms-api": {
            "Address": "http://wms-api:8080"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-api": {
            "Address": "http://payment-api:8080"
          }
        }
      }
    }
  }
}